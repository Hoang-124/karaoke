<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<div class="container mt-5" style="max-width: 500px;">
    <h2>
        <%= typeof booking !== 'undefined' && booking && booking._id ? 'Update Booking' : 'Add New Booking' %>
    </h2>
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger" role="alert">
            <%= error %>
        </div>
    <% } %>
    <form action="<%= typeof booking !== 'undefined' && booking && booking._id ? '/update-booking/' + booking._id : '/book-room' %>"
        method="POST">
        <div class="mb-3"><label>Customer Name</label><input type="text" name="customerName" class="form-control"
                value="<%= typeof booking !== 'undefined' && booking ? booking.customerName : '' %>" required></div>
        <div class="mb-3">
            <label>Room Number</label>
            <select name="roomNumber" class="form-select" required>
                <option value="">-- Select Room --</option>
                <% if (typeof rooms !== 'undefined' && rooms) { %>
                    <% rooms.forEach(room => { %>
                        <option value="<%= room.roomNumber %>" <%= (typeof booking !== 'undefined' && booking && booking.roomNumber === room.roomNumber) ? 'selected' : '' %>>
                            <%= room.roomNumber %> (<%= room.status %>)
                        </option>
                    <% }) %>
                <% } %>
            </select>
        </div>
        <div class="mb-3"><label>Start Time</label><input type="datetime-local" name="startTime" class="form-control"
                value="<%= typeof booking !== 'undefined' && booking && booking.startTime ? (booking.startTime instanceof Date ? booking.startTime.toISOString().slice(0,16) : booking.startTime) : '' %>"
                required></div>
        <div class="mb-3"><label>End Time</label><input type="datetime-local" name="endTime" class="form-control"
                value="<%= typeof booking !== 'undefined' && booking && booking.endTime ? (booking.endTime instanceof Date ? booking.endTime.toISOString().slice(0,16) : booking.endTime) : '' %>"
                required></div>
        <button type="submit" class="btn btn-success">Save</button>
        <a href="/bookings" class="btn btn-secondary">Cancel</a>
    </form>
</div>