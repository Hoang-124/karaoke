<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<div class="container mt-5">
    <h2>Room Booking List</h2>
    <table class="table table-bordered table-striped mt-3">
        <thead class="table-dark">
            <tr>
                <th>Customer Name</th>
                <th>Room</th>
                <th>Start</th>
                <th>End</th>
                <th>Total</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% bookings.forEach(b=> { %>
                <tr>
                    <td>
                        <%= b.customerName %>
                    </td>
                    <td>
                        <%= b.roomNumber %>
                    </td>
                    <td>
                        <%= b.startTime.toLocaleString() %>
                    </td>
                    <td>
                        <%= b.endTime.toLocaleString() %>
                    </td>
                    <td>
                        <%= b.totalAmount.toLocaleString() %>
                    </td>
                    <td>
                        <a href="/update-booking/<%= b._id %>" class="btn btn-warning btn-sm">Update</a>
                        <form action="/delete-booking/<%= b._id %>" method="POST" class="d-inline"><button
                                class="btn btn-danger btn-sm">Delete</button></form>
                    </td>
                </tr>
                <% }) %>
        </tbody>
    </table>
    <a href="/book-room" class="btn btn-primary">Add New Booking</a>
</div>